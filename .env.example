# Copy this to .env in the same directory as docker-compose.prod.yml on the Pi.
# This file is auto-loaded by Docker Compose for ${VAR} substitution.
# It is NOT injected into any container — safe to hold secrets used only at
# the Compose level (image tag resolution, DB init, Meilisearch init).
# NEVER commit .env to git.

# ── GitHub Container Registry ──────────────────────────────────────────────────
GITHUB_OWNER=your-github-username

# ── Secrets (use strong random values in production) ──────────────────────────
POSTGRES_PASSWORD=change_me_strong_password
MEILISEARCH_MASTER_KEY=change_me_strong_key
