# Copy this to .env.prod in the same directory as docker-compose.prod.yml on the Pi.
# Loaded ONLY into the backend container via `env_file: .env.prod`.
# Contains backend runtime vars only — no Compose-level secrets here.
# NEVER commit .env.prod to git.

# ── Database (must match POSTGRES_PASSWORD in .env) ────────────────────────────
DATABASE_URL=postgres://postgres:change_me_strong_password@postgres:5432/personal_care

# ── Meilisearch (MEILISEARCH_API_KEY must equal MEILISEARCH_MASTER_KEY in .env) ─
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_API_KEY=change_me_strong_key

# ── HTTP / CORS ────────────────────────────────────────────────────────────────
# Set to your Pi's LAN IP (find it with: hostname -I)
CORS_ORIGIN=http://192.168.1.100

# ── App ────────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
